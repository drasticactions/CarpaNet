<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!-- Locate the build task DLL: NuGet package layout first, then source build fallback -->
  <PropertyGroup>
    <_CarpaNetBuildTasksAssembly>$(MSBuildThisFileDirectory)..\tasks\net8.0\CarpaNet.BuildTasks.dll</_CarpaNetBuildTasksAssembly>
    <_CarpaNetBuildTasksAssembly Condition="!Exists('$(_CarpaNetBuildTasksAssembly)')">$(MSBuildThisFileDirectory)..\..\CarpaNet.BuildTasks\bin\$(Configuration)\net8.0\CarpaNet.BuildTasks.dll</_CarpaNetBuildTasksAssembly>
  </PropertyGroup>

  <!-- Register the lexicon resolver build task -->
  <UsingTask TaskName="CarpaNet.BuildTasks.ResolveLexiconTask"
             AssemblyFile="$(_CarpaNetBuildTasksAssembly)" />

  <!-- Default configuration for DNS-based lexicon resolution -->
  <PropertyGroup>
    <CarpaNet_LexiconCacheDir Condition="'$(CarpaNet_LexiconCacheDir)' == '' AND '$(BaseIntermediateOutputPath)' != ''">$(BaseIntermediateOutputPath)lexicon-cache\</CarpaNet_LexiconCacheDir>
    <CarpaNet_LexiconCacheDir Condition="'$(CarpaNet_LexiconCacheDir)' == ''">obj\lexicon-cache\</CarpaNet_LexiconCacheDir>
    <CarpaNet_LexiconCacheTtlHours Condition="'$(CarpaNet_LexiconCacheTtlHours)' == ''">24</CarpaNet_LexiconCacheTtlHours>
    <CarpaNet_LexiconFailOnError Condition="'$(CarpaNet_LexiconFailOnError)' == ''">true</CarpaNet_LexiconFailOnError>
    <CarpaNet_PlcDirectoryUrl Condition="'$(CarpaNet_PlcDirectoryUrl)' == ''">https://plc.directory</CarpaNet_PlcDirectoryUrl>
    <CarpaNet_DnsServers Condition="'$(CarpaNet_DnsServers)' == ''"></CarpaNet_DnsServers>
  </PropertyGroup>

  <ItemGroup>
    <CompilerVisibleProperty Include="CarpaNet_SourceGen_RootNamespace" />
    <CompilerVisibleProperty Include="CarpaNet_SourceGen_EmitValidationAttributes" />
    <CompilerVisibleProperty Include="CarpaNet_SourceGen_CborContextName" />
    <CompilerVisibleProperty Include="CarpaNet_SourceGen_JsonContextName" />
  </ItemGroup>

  <ItemGroup>
    <CompilerVisibleItemMetadata Include="AdditionalFiles" MetadataName="IsATProtoLexicon" />
  </ItemGroup>

  <!-- Resolve lexicons from DNS when LexiconResolve items are present -->
  <Target Name="_CarpaNetResolveLexicons"
          BeforeTargets="_CarpaNetMapLexiconFiles"
          Condition="'@(LexiconResolve)' != ''">
    <ResolveLexiconTask
      Nsids="@(LexiconResolve)"
      CacheDir="$(CarpaNet_LexiconCacheDir)"
      CacheTtlHours="$(CarpaNet_LexiconCacheTtlHours)"
      FailOnError="$(CarpaNet_LexiconFailOnError)"
      PlcDirectoryUrl="$(CarpaNet_PlcDirectoryUrl)"
      DnsServers="$(CarpaNet_DnsServers)">
      <Output TaskParameter="ResolvedLexiconFiles" ItemName="LexiconFiles" />
    </ResolveLexiconTask>
  </Target>

  <!-- Convert LexiconFiles items to AdditionalFiles with marker metadata -->
  <Target Name="_CarpaNetMapLexiconFiles"
          BeforeTargets="GenerateMSBuildEditorConfigFileShouldRun"
          DependsOnTargets="_CarpaNetResolveLexicons">
    <ItemGroup>
      <AdditionalFiles Include="@(LexiconFiles)" IsATProtoLexicon="true" />
    </ItemGroup>
  </Target>

</Project>
